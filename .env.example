# VibeLens Configuration
# Copy to .env and fill in values

# Server
VIBELENS_HOST=127.0.0.1
VIBELENS_PORT=12001

# Local Claude Code data directory
VIBELENS_CLAUDE_DIR=~/.claude

# MongoDB (optional)
VIBELENS_MONGODB_URI=
VIBELENS_MONGODB_DB=vibelens

# HuggingFace (optional)
VIBELENS_HF_TOKEN=

# Database
VIBELENS_DB_PATH=~/.vibelens/vibelens.db
